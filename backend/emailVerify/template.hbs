<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify Your Email</title>
</head>

<body style="margin:0; padding:0; background-color:#0B0F1A; font-family:Segoe UI, sans-serif;">

    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#0B0F1A; padding:40px 0;">
        <tr>
            <td align="center">

                <!-- Main Container -->
                <table width="600" cellpadding="0" cellspacing="0" border="0"
                    style="background-color:#111827; border-radius:16px; padding:40px; box-shadow:0 0 40px rgba(168,85,247,0.2);">

                    <!-- Header -->
                    <tr>
                        <td align="center" style="padding-bottom:20px;">
                            <h2 style="color:#ffffff; margin:0; font-size:26px;">
                                Verify Your Email Address
                            </h2>
                            <p style="color:#9CA3AF; font-size:14px; margin-top:8px;">
                                Activate your account securely
                            </p>
                        </td>
                    </tr>

                    <!-- Message -->
                    <tr>
                        <td style="color:#D1D5DB; font-size:16px; line-height:1.6;">
                            <p>Hello,</p>

                            <p>
                                Thank you for signing up. To complete your registration and activate your account,
                                please verify your email address by clicking the button below.
                            </p>

                            <p style="text-align:center; margin:30px 0;">
                                <a href="http://localhost:5173/verify/{{token}}" target="_blank"
                                    style="background: linear-gradient(90deg,#7C3AED,#2563EB); padding:14px 28px; color:#ffffff !important; text-decoration:none;border-radius:10px; font-weight:600; display:inline-block;box-shadow:0 0 20px rgba(124,58,237,0.4);">
                                    Verify Email
                                </a>
                            </p>

                            <p>
                                If you did not create this account, you can safely ignore this email.
                            </p>

                            <p style="font-size:14px; color:#9CA3AF;">
                                This link will expire in 15 minutes for security reasons.
                            </p>
                        </td>
                    </tr>

                    <!-- Divider -->
                    <tr>
                        <td style="border-top:1px solid rgba(255,255,255,0.1); padding-top:20px; margin-top:20px;">
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td align="center" style="color:#6B7280; font-size:12px; padding-top:10px;">
                            © 2026 Smart AI Planner. All rights reserved. <br />
                            This is an automated message — please do not reply.
                        </td>
                    </tr>

                </table>

            </td>
        </tr>
    </table>

</body>

</html>